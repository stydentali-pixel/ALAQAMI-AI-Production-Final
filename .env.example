# ── ALAQAMI AI — environment variables ─────────────────────────────────────

# Required for Mode 2 (server-side encrypted provider storage) and for
# any authenticated route (/api/auth/*, /api/settings). Must be a strong
# random secret, 32+ characters. Rotating this value invalidates every
# previously-encrypted provider API key — plan key rotation accordingly.
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=

# Where the on-disk JSON database file lives. Defaults to ./db relative to
# the process working directory. In the packaged/self-hosted deployment
# (.zscripts/start.sh) this should point at a persistent volume, e.g. /app/db.
DATA_DIR=./db

# Optional: override the store's filename (default: store.json).
DATA_FILE_NAME=store.json

# ── Existing BYOK / server-fallback provider keys (unchanged) ─────────────
# Any of these, if set, let that provider work without the user supplying
# their own key in Mode 1 (BYOK) requests. See src/lib/providers/catalog.ts
# for the full list of `serverEnvKey` names.
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
