# ── ALAQAMI AI — environment variables ─────────────────────────────────────

# ── Database (Supabase PostgreSQL via Prisma) ─────────────────────────────
# DATABASE_URL : pooled connection (Supavisor / PgBouncer, port 6543) used by
#                the app at runtime. Must include ?pgbouncer=true.
# DIRECT_URL   : direct/session connection (port 5432) used by Prisma
#                Migrate for running migrations.
# Get both from Supabase → Project Settings → Database → Connection string.
DATABASE_URL=
DIRECT_URL=

# ── Supabase project (public + service role) ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required for Mode 2 (server-side encrypted provider storage) and for
# any authenticated route (/api/auth/*, /api/settings). Must be a strong
# random secret, 32+ characters. Rotating this value invalidates every
# previously-encrypted provider API key — plan key rotation accordingly.
# Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=

# ── Existing BYOK / server-fallback provider keys (unchanged) ─────────────
# Any of these, if set, let that provider work without the user supplying
# their own key in Mode 1 (BYOK) requests. See src/lib/providers/catalog.ts
# for the full list of `serverEnvKey` names.
AI_GATEWAY_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
